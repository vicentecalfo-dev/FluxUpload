{
  "name": "@flux-upload/ui-shadcn",
  "version": "0.1.0",
  "description": "shadcn/ui-based components for Flux Upload.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
